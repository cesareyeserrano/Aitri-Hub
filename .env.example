# Aitri Hub — Environment Variables
# Copy to .env and adjust as needed.
# All variables have safe defaults — only override when necessary.

# Directory where Aitri Hub stores its state, cache, and logs.
# Default: ~/.aitri-hub
AITRI_HUB_DIR=

# Port for the web dashboard (Docker).
# Default: 3000
AITRI_HUB_PORT=3000

# Refresh interval for the CLI monitor (milliseconds).
# Default: 5000
AITRI_HUB_REFRESH_MS=5000

# Timeout for git exec calls (milliseconds).
# Default: 5000
AITRI_HUB_GIT_TIMEOUT_MS=5000

# Maximum number of registered projects.
# Default: 50
AITRI_HUB_MAX_PROJECTS=50

# Stale commit threshold (hours). Projects with no commits beyond this trigger an alert.
# Default: 72
AITRI_HUB_STALE_HOURS=72
