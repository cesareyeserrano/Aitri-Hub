# Aitri Hub v0.3.0 Redesign — Environment Variables
# Copy to .env and adjust as needed. All variables have safe defaults; override only
# when necessary. The redesign introduces NO new environment variables — it reuses the
# existing Hub config. Documented here for completeness (name · type · required · example).

# Directory where Aitri Hub stores state, cache, logs, and the QA store (qa/).
# type: path · required: optional · default: ~/.aitri-hub
AITRI_HUB_DIR=

# Port for the web dashboard (bound to 127.0.0.1 only).
# type: integer · required: optional · default: 3000
AITRI_HUB_PORT=3000

# Refresh interval for the collector / monitor.
# type: integer (ms) · required: optional · default: 5000
AITRI_HUB_REFRESH_MS=5000

# Per-project git exec timeout.
# type: integer (ms) · required: optional · default: 5000
AITRI_HUB_GIT_TIMEOUT_MS=5000
