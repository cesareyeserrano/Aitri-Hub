# Aitri Hub feature deployment examples

# AITRI_HUB_DIR
# Type: absolute path
# Required: optional
# Example: /data
AITRI_HUB_DIR=/data

# AITRI_HUB_PORT
# Type: integer TCP port
# Required: optional
# Example: 3000
AITRI_HUB_PORT=3000

# AITRI_HUB_REFRESH_MS
# Type: integer milliseconds
# Required: optional
# Example: 5000
AITRI_HUB_REFRESH_MS=5000

# AITRI_HUB_SCAN_DIR
# Type: absolute path list separated by the host path delimiter
# Required: optional
# Example: /workspace/projects
AITRI_HUB_SCAN_DIR=

# AITRI_HUB_DATA_DIR
# Type: host path for docker-compose volume mount
# Required: optional
# Example: ./data
AITRI_HUB_DATA_DIR=./data
