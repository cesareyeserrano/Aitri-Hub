# Aitri Hub — hub-mvp-web environment variables

# Port the web server listens on
# Type: number
# Required: optional (default: 3000)
# Example: 3000
AITRI_HUB_PORT=3000

# Directory where projects.json and dashboard.json are stored
# Type: string (absolute path)
# Required: optional (default: ~/.aitri-hub)
# Example: /home/user/.aitri-hub
AITRI_HUB_DIR=~/.aitri-hub
