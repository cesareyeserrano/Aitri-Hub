# .env.example — integration-last-reviewed-gate
#
# Copy to .env and adjust values for your environment.
# This feature introduces no required environment variables.
# All entries below are optional overrides.

# Port for the web dashboard container
# Default: 3000
WEB_PORT=3000

# Path to the aitri-hub data directory on the host
# Default: ~/.aitri-hub
AITRI_HUB_DIR=~/.aitri-hub

# Node environment (production | development)
# Default: production
NODE_ENV=production

# Test-only: override hub data directory in tests (do not set in production)
# AITRI_HUB_DIR_OVERRIDE=/tmp/hub-test-xyz
