# .env.example — integration_update feature
# No new environment variables are introduced by this feature.
# The following are inherited from the base aitri-hub project:

# Directory where Hub stores state (default: ~/.aitri-hub)
# AITRI_HUB_DIR=~/.aitri-hub

# Collection refresh interval in milliseconds (default: 5000)
# AITRI_HUB_REFRESH_MS=5000

# Hours without commits before a project is marked stale (default: 72)
# AITRI_HUB_STALE_HOURS=72

# Maximum number of projects to monitor (default: 50)
# AITRI_HUB_MAX_PROJECTS=50
